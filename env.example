# ──────────────────────────────────────────────────────────────
# Variables d'environnement — FFBB Arbitrage Backend
# Copiez ce fichier en .env et remplissez les valeurs.
# NE commitez JAMAIS le fichier .env dans Git !
# Sur Render/Railway, saisissez ces variables dans l'interface web.
# ──────────────────────────────────────────────────────────────

# Vos identifiants FBI (extranet.ffbb.com)
FBI_USERNAME=votre_identifiant_ou_email@exemple.com
FBI_PASSWORD=votre_mot_de_passe

# Token secret pour protéger votre API
# Générez-en un solide : python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN=ffbb2026secret

# Durée du cache en secondes (défaut : 21600 = 6 heures)
CACHE_TTL_SECONDS=21600

# Origines autorisées pour CORS (votre frontend)
# Ex: https://mon-dashboard.vercel.app,https://monarbitre.fr
ALLOWED_ORIGINS=*

# Port (géré automatiquement par Render/Railway)
PORT=5000

# Passer à true pour les logs détaillés (désactiver en prod)
DEBUG=false
